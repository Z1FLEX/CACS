# ========================
# DATABASE (Postgres)
# ========================
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# ========================
# JPA / HIBERNATE
# ========================
SPRING_JPA_HIBERNATE_DDL_AUTO=
SPRING_JPA_SHOW_SQL=

# ========================
# REDIS
# ========================
SPRING_DATA_REDIS_HOST=
SPRING_DATA_REDIS_PORT=

# ========================
# JWT
# ========================
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION=
JWT_REFRESH_TOKEN_EXPIRATION=

# ========================
# FRONTEND
# ========================
VITE_API_BASE_URL=
SERVER_NAME=

# ========================
# PUBLIC APP URL
# ========================
PUBLIC_BASE_URL=

# ========================
# TLS (Production Frontend)
# ========================
TLS_LETSENCRYPT_DIR=./infra/letsencrypt
TLS_CERTIFICATE_PATH=/etc/letsencrypt/live/your-domain/fullchain.pem
TLS_CERTIFICATE_KEY_PATH=/etc/letsencrypt/live/your-domain/privkey.pem
HSTS_HEADER_VALUE=max-age=31536000
CERTBOT_EMAIL=
CERTBOT_DOMAINS=
